---
import LandingLayout from '../layouts/LandingLayout.astro';
import ReviewsCarousel from '../components/landing/ReviewsCarousel.astro';
import RelatedServices from '../components/landing/RelatedServices.astro';
import reviews from '../data/reviews-human-design.json';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const tiers = [
  {
    name: 'Начало самопознания',
    price: '3 000 ₽',
    priceNote: '40 минут',
    lead: 'Первичная информация и ответы на готовые вопросы.',
    items: [
      'Сессия-знакомство 40 минут онлайн',
      'Стратегия и внутренний авторитет',
      'Ответы на ваши готовые вопросы',
      'Запись встречи',
    ],
    ctaLabel: 'Записаться',
  },
  {
    name: 'Полный разбор',
    price: '14 000 ₽',
    priceNote: '2 × 1 час',
    lead: 'Две часовых консультации с полным разбором карты и профиля.',
    items: [
      'Две часовых консультации онлайн',
      'Информация обо всех центрах (чакрах)',
      'Порядок проработок Генных Ключей',
      'Чтение бодиграфа',
      'Хологенетический профиль',
      'Интегральный Дизайн Человека',
      'Запись встреч',
    ],
    ctaLabel: 'Записаться',
    featured: true,
  },
  {
    name: 'Индивидуальное погружение',
    price: '60 000 ₽',
    priceNote: '2 месяца',
    lead: 'Авторские практики, терапевтические медитации и освоение ИДЧ в повседневной жизни.',
    items: [
      'Два месяца теории и практики',
      '5 часовых консультаций',
      '2 большие встречи (2+ часа) с медитациями',
      'Работа с запросами даже вне Дизайна Человека',
      'Хологенетический профиль, бодиграф и все центры',
      'Терапевтические медитации под запрос',
      'Запись всех встреч',
    ],
    ctaLabel: 'Записаться',
  },
];

const faqs = [
  {
    q: 'Что делать, если не знаю точное время рождения?',
    a: 'Зависит от того, насколько известен промежуток. Если это несколько часов — можно посмотреть, возможно изменения будут минимальны и это не повлияет на консультацию. Если известна только дата — есть смысл задуматься о ректификации времени рождения (процедуре уточнения). Ректификацию можно сделать разными способами: заказать у астролога; воспользоваться инструментами для сонастройки с интуицией (маятник, карты, мускульный тест); или запросить ответ у Высшего Я (Души). В некоторых ситуациях я могу проконсультировать и не зная времени — это решается индивидуально. Обращайтесь — обсудим.',
  },
  {
    q: 'Получу ли я свою карту с бодиграфом и хологенетическим профилем?',
    a: 'Да, вы получите ссылки на все необходимые сайты, где можно посмотреть бодиграф, активные центры и каналы, хологенетический профиль, последовательности и сферы Золотого Пути.',
  },
  {
    q: 'Узнаю ли я своё предназначение? В чём моя миссия? Какое у меня призвание?',
    a: 'Предназначение — в каждом моменте жизни, в каждом вдохе и действии. Интегральный Дизайн Человека помогает сонастроиться с собой и с ощущением, что идёшь по своему пути, а также подсвечивает темы, которые нужно проработать для реализации в социуме. Для реализации предназначения важно понимать свои интересы и уметь освобождаться от эмоциональных блоков. ИДЧ не говорит, на какую пойти работу — скорее показывает энергии, которые необходимо проявлять, чтобы быть собой в любом месте и притягивать единомышленников по миссии в этом воплощении.',
  },
  {
    q: 'Что делать, если я уже немного понимаю Дизайн Человека и у меня есть один-два конкретных вопроса?',
    a: 'Вам подойдёт 45-минутная консультация. Напишите мне вопрос, познакомимся — и я уточню вашу тему своим пониманием Генных Ключей, Интегрального Дизайна Человека и духовной психологии.',
  },
  {
    q: 'Поможет ли мне Интегральный Дизайн Человека обрести вдохновение?',
    a: 'Согласно Дизайну Человека у каждого есть свой уникальный способ принятия решения и навигации в этом мире. На консультациях я показываю, как сонастроиться с собственным вкусом вдохновения. Генные Ключи помогают поднять вибрации своих энергий и проявлять те же качества, больше испытывая открытость, любовь, желание сотворять и служить.',
  },
  {
    q: 'Поможет ли мне Интегральный Дизайн Человека нащупать источник счастья?',
    a: 'Работа с Генными Ключами направлена на исцеление сердца — то есть духовную психотерапию. Самый главный источник счастья у нас внутри, и чтобы полноценно им пользоваться, нужно взять ответственность за своё исцеление. Золотой Путь показывает ключевые темы, которые нужно проработать для открытия внутреннего источника любви и исцеления травмы (сферы Духовный Интеллект и Ядро Сакральной Раны в Хологенетическом Профиле).',
  },
  {
    q: 'Интегральный Дизайн Человека расскажет о моих взаимоотношениях с противоположным полом?',
    a: 'Дизайн Человека рассказывает, какие энергии взаимно притягивают партнёров, как они усиливают друг друга и где могут друг друга подавлять. В Генных Ключах активации Луны, Венеры и Марса показывают темы, необходимые для исцеления кармы через отношения: что нужно в себе осознать, чтобы стабильнее чувствовать себя в отношениях и притягивать партнёра, наиболее полезного для духовного пути. Большое внимание уделяется Сакральной Ране — она актуальна для исцеления любых травм.',
  },
  {
    q: 'Я узнаю свои сильные и слабые стороны? В чём моя уникальность?',
    a: 'У каждого могут быть любые сильные и слабые стороны, зависящие от многих факторов: наработок Рода, опыта Души, культуры, в которой человек вырос. Генные Ключи показывают постоянно свойственные вам энергии (темы в жизни), как они проявляются на низких вибрациях и что делать, чтобы переходить на высокие — другими словами, как свои слабые стороны перевести в сильные. Дизайн Человека показывает, на каких темах не нужно слишком много заморачиваться (Ложное Я), а на что в себе полагаться как на приоритетные качества личности (Внутренний Авторитет).',
  },
  {
    q: 'Как лучше себя узнать и понять?',
    a: 'Дизайн Человека показывает грани, на которые можно в себе всегда положиться (Внутренний Авторитет). Через эти темы происходит сонастройка с телом, а тело — благодаря контакту с подсознанием — чувствует нашу судьбу и помогает идти по ней наиболее гармоничным образом. Генные Ключи показывают темы, которые вы «не можете не делать». Развитие основных качеств гарантирует рост и усиление — через них проще всего начать самопознание.',
  },
  {
    q: 'Поможет ли ИДЧ понять, какие принять решения?',
    a: 'Во время консультации я рассказываю, на какой из внутренних голосов полагаться в принятии решений, и лучшую стратегию для сонастройки с телом и Высшим Я. В разных ситуациях нужно пользоваться разными своими гранями, чем-то вроде внутренних голосов. Согласно Интегральному Дизайну Человека, мы можем развить в себе их все — потому что по своей природе мы целостны. Отличать один голос (энергетический центр) от другого и сонастраиваться с ними вы сможете, пройдя погружение в ИДЧ.',
  },
  {
    q: 'Поможет ли ИДЧ принять и полюбить себя?',
    a: 'Последовательность Венеры — это специальные активации, темы, прорабатывая которые вы открываете своё сердце. Генные Ключи хорошо согласуются с современными методами психотерапии и направлены на самостоятельное глубинное исцеление.',
  },
  {
    q: 'Что проработать, чтобы были деньги? Что мешает процветанию?',
    a: 'Интегральный Дизайн Человека показывает «племенные» активации в карте — это темы, проработка которых актуальна в этом воплощении. Их энергии направлены на взаимодействие с людьми в команде, взаимное сотрудничество, заработок денег и процветание. Они также показывают подходящие роли в команде. В Генных Ключах Жемчужная Последовательность показывает, как активации Юпитера увеличивают социальную энергию (деньги!) и дают нужные знакомства. На полном разборе я рассказываю обо всех этих темах, а также о Сакральной Ране — кульминации Золотого Пути, — чтобы травма не остановила вас от служения и реализации.',
  },
  {
    q: 'Как мне подавать, продавать, транслировать себя?',
    a: 'Интегральный Дизайн Человека показывает стратегию принятия решений и роль в обществе (профиль и линии). В Генных Ключах «Бренд» указывает ваш способ самопрезентации, чтобы общество воспринимало вас аутентично. Активации Меркурия показывают идеи, которые вам естественно транслировать в обществе.',
  },
  {
    q: 'Я уже пытался разобраться в Дизайне Человека или Генных Ключах, но у меня нет ясной картинки.',
    a: 'На полном разборе за 2 встречи я помогаю осознать все свои активации и даю обратную связь по вашим примерам — чтобы вы могли соотнести эти абстракции со своим конкретным опытом.',
  },
];

const sources = [
  { label: 'Астрология' },
  { label: 'Чакры' },
  { label: 'И-Цзин', sub: 'Книга Перемен' },
  { label: 'Нью-Эйдж', sub: 'и эзотерика' },
  { label: 'Психотерапия' },
  { label: 'Уроки Души' },
];

const bioList = [
  'Работа с Дизайном Человека и Генными Ключами — 7 лет',
  'Ведущий терапевтических медитаций',
  'Опыт в психотерапии — 8 лет',
  'Обучался психологии у Екатерины Самойловой',
  'Опыт в соционике — 12 лет',
  'Ученик Семёна Чурюмова',
  'Более 2 000 типирований',
  'Более 20 докладов на соционических конференциях',
];

const stats = [
  { value: '7+', label: 'лет с Дизайном Человека' },
  { value: '8+', label: 'лет психотерапевтической практики' },
  { value: '12+', label: 'лет в соционике' },
];
---

<LandingLayout
  title="Интегральный Дизайн Человека — Сергей Шанэри"
  description="Консультации по Дизайну Человека и Генным Ключам в подходе духовной психотерапии. Бодиграф, хологенетический профиль, Золотой Путь, Генные Ключи."
  canonical="human-design/"
>
  {/* ─────────────────── HERO ─────────────────── */}
  <section class="hero">
    <div class="hero__aurora" aria-hidden="true"></div>
    <div class="ln-shell ln-shell--narrow hero__inner">
      <div class="hero__meta" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Консультации · Сергей Шанэри
        </span>
      </div>

      <h1 class="ln-display hero__title" data-reveal data-reveal-delay="1">
        Интегральный<br />
        Дизайн Человека.<br />
        <em>Духовная психотерапия.</em>
      </h1>

      <p class="ln-lead hero__lead" data-reveal data-reveal-delay="2">
        Помогу воспользоваться выводами из систем самопознания —
        без погружения в теорию.
      </p>

      <div class="hero__actions" data-reveal data-reveal-delay="3">
        <a class="ln-btn ln-btn--primary" href={`${base}contact/`}>
          <span class="ln-btn__shine" aria-hidden="true"></span>
          <span>Записаться</span>
          <span class="ln-btn__icon" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M4 12L12 4M12 4H6M12 4V10" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
        <a class="ln-btn ln-btn--ghost" href="#pricing">
          <span>Что входит</span>
          <span class="ln-btn__icon" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M4 6L8 10L12 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      </div>

      <div class="hero__stats" data-reveal data-reveal-delay="4">
        {stats.map((s) => (
          <div class="hero__stat">
            <span class="hero__stat-value">{s.value}</span>
            <span class="hero__stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-label">Прокрутить</span>
      <span class="hero__scroll-line"></span>
    </div>
  </section>

  {/* ─────────────────── МЕТОД + ВИДЕО ─────────────────── */}
  <section class="intro ln-section">
    <div class="ln-shell intro__grid">
      <header class="intro__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Подход
        </span>
        <h2 class="ln-h2 intro__title">
          Инструмент<br />
          <em>передовой духовной психотерапии.</em>
        </h2>
        <p class="ln-body intro__body">
          ИДЧ — совокупность систем самопознания, которые помогают работать
          с&nbsp;предназначением, сильными сторонами, осознанностью, а&nbsp;также
          эмоциями, личными травмами и&nbsp;отношениями.
        </p>

        <blockquote class="intro__quote">
          <span aria-hidden="true" class="intro__quote-mark">“</span>
          <p>
            На своих консультациях я&nbsp;варьирую методы под запрос, клиента
            и&nbsp;состояние — работаю по&nbsp;потоку.
          </p>
        </blockquote>

        <p class="ln-body intro__body">
          Запись консультации поможет освежить выводы — информации и&nbsp;инсайтов
          много. Для новичков я&nbsp;вижу пользу в&nbsp;том, чтобы понять,
          как принимать решения, что в&nbsp;себе слушать и&nbsp;чего не&nbsp;делать.
        </p>

        <a class="ln-underlink" href={`${base}podcast-human-design/`}>
          <span>Подробный подкаст про Дизайн Человека и Генные Ключи</span>
          <span aria-hidden="true">→</span>
        </a>
      </header>

      <div class="intro__media" data-reveal data-reveal-delay="2">
        <div class="ln-bezel intro__video-bezel">
          <div class="ln-bezel__inner intro__video-inner">
            <iframe
              src="https://www.youtube-nocookie.com/embed/MfoToyRdsaM"
              title="Интегральный Дизайн Человека — введение"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
        <p class="intro__caption">
          <em>Короткое введение в подход: что такое Интегральный Дизайн Человека и зачем.</em>
        </p>
      </div>
    </div>

    <div class="ln-shell intro__sources" data-reveal data-reveal-delay="3">
      <span class="intro__sources-title">
        Интегральный Дизайн Человека объединяет идеи из&nbsp;систем
      </span>
      <ul class="intro__source-grid">
        {sources.map((s) => (
          <li class="intro__source-item">
            <svg class="intro__source-mark" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
              <circle cx="6" cy="6" r="4.5" opacity="0.35" />
              <circle cx="6" cy="6" r="1.5" fill="currentColor" stroke="none" />
            </svg>
            <span class="intro__source-label">
              {s.label}
              {s.sub && <span class="intro__source-sub">{s.sub}</span>}
            </span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ─────────────────── ТАРИФЫ ─────────────────── */}
  <section id="pricing" class="pricing ln-section">
    <div class="ln-shell ln-shell--wide">
      <header class="pricing__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Стоимость
        </span>
        <h2 class="ln-h2 pricing__title">
          Три формата —<br />
          <em>подбираем под запрос.</em>
        </h2>
      </header>

      <div class="pricing__grid">
        {tiers.map((tier, i) => (
          <article
            class:list={['pricing__card ln-bezel', tier.featured && 'pricing__card--featured']}
            data-reveal
            data-reveal-delay={i + 1}
          >
            <div class="ln-bezel__inner pricing__card-inner">
              <header class="pricing__card-head">
                <h3 class="ln-h3 pricing__card-name">{tier.name}</h3>
                <p class="pricing__card-lead">{tier.lead}</p>
              </header>

              <div class="pricing__price">
                <span class="pricing__price-value">{tier.price}</span>
                <span class="pricing__price-note">{tier.priceNote}</span>
              </div>

              <ul class="pricing__features">
                {tier.items.map((item) => (
                  <li>
                    <svg class="pricing__check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
                      <path d="M3 8.5L6.5 12L13 4.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>

              <a
                class:list={['pricing__cta', 'ln-btn', tier.featured ? 'ln-btn--primary' : 'ln-btn--ghost']}
                href={`${base}contact/`}
              >
                {tier.featured && <span class="ln-btn__shine" aria-hidden="true"></span>}
                <span>{tier.ctaLabel}</span>
                <span class="ln-btn__icon" aria-hidden="true">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
                    <path d="M4 12L12 4M12 4H6M12 4V10" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </a>

              {tier.featured && <span class="pricing__badge">Основной</span>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ─────────────────── ОТЗЫВЫ ─────────────────── */}
  <section class="reviews ln-section">
    <div class="ln-shell">
      <header class="reviews__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Отзывы
        </span>
        <h2 class="ln-h2 reviews__title">
          Что говорят<br />
          <em>те, кто уже прошёл.</em>
        </h2>
      </header>

      <div data-reveal data-reveal-delay="1">
        <ReviewsCarousel reviews={reviews} id="hd" />
      </div>
    </div>
  </section>

  {/* ─────────────────── FAQ ─────────────────── */}
  <section class="faq ln-section">
    <div class="ln-shell faq__grid">
      <header class="faq__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Частые вопросы
        </span>
        <h2 class="ln-h2 faq__title">
          Частые<br />
          <em>вопросы.</em>
        </h2>
        <p class="ln-body faq__body">
          Если вашего вопроса нет — задайте его в&nbsp;

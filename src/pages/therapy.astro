    pointer-events: none;
    background:
      radial-gradient(ellipse 40% 35% at 22% 58%, rgba(154, 120, 255, 0.35), transparent 65%),
      radial-gradient(ellipse 35% 30% at 78% 42%, rgba(80, 120, 255, 0.22), transparent 65%),
      radial-gradient(ellipse 30% 25% at 50% 92%, rgba(168, 232, 205, 0.18), transparent 60%);

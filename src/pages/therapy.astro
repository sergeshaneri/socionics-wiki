    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(7rem, 12vh, 9rem) 0 clamp(4rem, 8vh, 6rem);
    overflow: hidden;
  }

  .hero__aurora {
    position: absolute;
    inset: -20% -10% 10%;

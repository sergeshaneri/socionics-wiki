---
import LandingLayout from '../layouts/LandingLayout.astro';
import ReviewsCarousel from '../components/landing/ReviewsCarousel.astro';
import RelatedServices from '../components/landing/RelatedServices.astro';
import JsonLd from '../components/JsonLd.astro';
import { serviceSchema } from '../lib/structured-data';
import reviews from '../data/reviews-therapy.json';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const therapyServiceSchema = serviceSchema({
  name: 'Духовная психотерапия',
  description:
    'Индивидуальные терапевтические сессии и целительные медитации в духовном подходе. Работа с эмоциями, травмами и духовными уроками. Гештальт, ЭОТ, гипнотерапия, регрессии в прошлые жизни, системные расстановки, работа с субличностями.',
  serviceType: 'Психотерапия',
  url: 'https://sergeshaneri.github.io/socionics-wiki/therapy/',
  lowPrice: 1000,
  highPrice: 30000,
});

const tiers = [
  {
    name: 'Ознакомительная',
    price: '1 000 ₽',
    priceNote: '30 минут',
    lead: 'Знакомство, выяснение запроса и план работы.',
    items: [
      'Консультация-знакомство 30 минут онлайн',
      'Выяснение запроса, подбор инструментов',
      'Определение возможных причин ситуации',
      'Определение духовных уроков',
      'Составление плана действий',
      'Запись встречи',
    ],
    ctaLabel: 'Записаться',
  },
  {
    name: 'Целительная сессия',
    price: '7 000 ₽',
    priceNote: '1–2 часа',
    lead: 'Консультация с определением духовного урока и терапевтической медитацией.',
    items: [
      'Психологическая беседа о сложностях',
      'Помощь в понимании эмоций',
      'Прояснение негативного паттерна и его причин',
      'Определение духовного урока',
      'Терапевтическая медитация под запрос',
      'Запись встречи',
    ],
    ctaLabel: 'Записаться',
    featured: true,
  },
  {
    name: 'Пакет сессий',
    price: 'от 30 000 ₽',
    priceNote: '5 / 10 / 20 часов',
    lead: 'Продолжительное ведение и глубинные целительные отношения.',
    items: [
      '5 ч — 30 000 ₽ · 10 ч — 55 000 ₽ · 20 ч — 100 000 ₽',
      'Комплексная проработка разных ситуаций',
      'Вырабатывание новых паттернов счастливой жизни',
      'Глубокие целительные отношения терапевт-клиент',
      'Интеграция соционики, ИДЧ, коучинга',
      'Групповые практики для постоянных клиентов в подарок',
      'Записи всех встреч',
    ],
    ctaLabel: 'Записаться',
  },
];

const faqs = [
  {
    q: 'Где вы учились?',
    a: 'Я обучался Духовной Психологии у Екатерины Самойловой и Александра Меньшикова.',
  },
  {
    q: 'Это с применением гипноза?',
    a: 'Трансформационные практики — это ведомые медитации, в которых я погружаю клиента в лёгкий гипноз. С точки зрения нейрофизиологии мозг работает в состоянии тета-волн, что способствует изменению состояния сознания и глубокому контакту с подсознанием. Это особо эффективное состояние для психотерапии; после встречи клиент помнит всё, что с ним происходило.',
  },
  {
    q: 'Психотерапия — это таблетки и антидепрессанты?',
    a: 'В России под психотерапевтами часто понимают врачей-психиатров, которые ставят диагноз (синдром или расстройство) и прописывают медикаментозное лечение. В других странах под терапевтом обычно понимают психолога, который помогает трансформировать тяжёлые чувства и исцелить личность. Я не врач-психиатр и не прописываю лекарства.',
  },
  {
    q: 'Узнаю ли я, какое у меня расстройство личности или синдром?',
    a: 'Нет, для этого нужно обратиться к врачу-психиатру. Мой подход строится вокруг духовных уроков и того, что у нас достаточно сил внутри для прохождения своего жизненного пути. Я помогаю выстраивать контакт с внутренним Источником и черпать в нём психологические ресурсы.',
  },
  {
    q: 'Смогу ли я снять порчу, сглаз, проклятие, подключку, лярву, сущность?',
    a: 'Всё служит нашему благу. Если в вашей жизни случились черно-магические воздействия, то это обязательно несёт духовный урок. Если понять, в чём суть урока, простить всех участников процесса, исцелить первичную ситуацию — можно освободиться от негативного воздействия. Главное — осознанно выбирать усваивать свой духовный урок более гармонично, тогда негативным энергиям не будет необходимости возвращаться.',
  },
  {
    q: 'Это религиозные практики?',
    a: 'Духовная психология не является частью организованных религий — это смесь New Age концепций и прикладных психотерапевтических методик. Это не ритуалы и обряды; обращение к Богу и Душе идёт от сердца, и вы всё делаете сами. Нам не нужен посредник и специальные условия для контакта с Богом — он всегда рад нам помочь, нужно только открыться.',
  },
  {
    q: 'Вдруг это всё кажется?',
    a: 'Для мозга нет разницы между реальностью и иллюзией — это всё происходит в восприятии. Поэтому работа с чувствами и ситуациями в воображении оказывает прямое воздействие на мозг и личность. Терапия всё равно происходит, даже если относиться к духовной составляющей как к метафоре.',
  },
  {
    q: 'Что делать, если я ничего не вижу в медитациях и у меня не работает интуиция?',
    a: 'Часто мы закрываем свои способности, потому что их использование когда-то было для нас небезопасным. Я провожу специальные практики по исцелению интуиции. Интуицию можно развивать разными способами — главное тренироваться и доверять себе. Есть разные формы считывания: визуальные, аудиальные образы, телесные ощущения, прямое знание, считывание через эмоции. В совместной работе мы определим подходящий для вас способ и улучшим с ним контакт.',
  },
  {
    q: 'Что делать, если я не понимаю свои чувства?',
    a: 'Навык осознавать свои чувства, называть и проживать их — основной в психотерапии и очень необходимый в духовных практиках. Если у вас с ним сложности — мы обязательно будем с ним работать и разбираться в причинах трудностей. Мои групповые терапевтические практики ТЭО (Техника Эмоциональной Осознанности) помогают в развитии чувствительности и эмоционального интеллекта.',
  },
  {
    q: 'Смогу ли я раскрыть свои чакры и энергоканалы?',
    a: 'В духовной психотерапии мы работаем с энерготелами и энергопотоками: блоки в чакрах часто связаны с психологическими травмами и программами, которые мы прорабатываем. Для усиления эффекта поможет, если вы также будете заниматься другими практиками: йога, цигун, дыхательные практики, энергомедитации, ченнелинги.',
  },
  {
    q: 'Погружаете ли вы в прошлые жизни?',
    a: 'Регрессии в прошлые жизни используются, если корень негативных сценариев лежит в прошлых жизнях, если конфликт с человеком связан с прошлыми жизнями, или если нужно наполниться психологическим ресурсом, который был в других воплощениях.',
  },
];

const concerns = [
  'Не чувствую свою ценность',
  'Не принимаю свою силу',
  'Не доверяю себе',
  'Не понимаю, что тормозит',
  'Потерянность в жизни',
  'Трачу время зря',
  'Зависимости',
  'Не понимаю предназначение',
  'Одиночество',
  'Созависимость в отношениях',
  'Не отпускаю прошлые отношения',
  'Сложные отношения с родителями',
  'Кризисные состояния',
  'Апатия · вина · стыд · горе',
];

const approaches = [
  'Гештальт-терапия',
  'Эмоционально-образная терапия',
  'Системные семейные расстановки',
  'Духовная психология',
  'Коучинг',
  'Гипнотерапия',
  'Целительные медитации',
  'Работа с субличностями',
  'Регрессии в прошлые жизни',
  'История рода',
  'Исцеление травм детства',
  'Родовые практики',
  'Энерготерапия',
  'Манифестации',
];

const outcomes = [
  'Увеличение энергии',
  'Желание жить',
  'Психологическая самодостаточность',
  'Избавление от негативных сценариев',
  'Лучше слышу интуицию',
  'Доверие себе',
  'Лучше понимаю себя',
  'Навыки психологической скорой помощи',
  'Социальный рост и самооценка',
  'Гармонизация отношений с партнёром',
  'Понимание точек роста',
  'Ясность «куда и для чего»',
  'Прощение и сепарация с родителями',
  'Отпускание прошлых отношений',
  'Освобождение от тяжёлых чувств',
  'Глубинное соединение с собой',
  'Жизнь из своего центра',
  'Состояние потока',
];

const bioList = [
  'Обучался Духовной Психологии у Екатерины Самойловой и Александра Меньшикова',
  'Опыт в психотерапии — 8 лет',
  'Ведущий терапевтических медитаций',
  'Работа с Дизайном Человека и Генными Ключами — 7 лет',
  'Опыт в соционике — 12 лет',
  'Ученик Семёна Чурюмова',
  'Более 2 000 типирований',
  'Более 20 докладов на соционических конференциях',
];

const stats = [
  { value: '8+', label: 'лет практики в психотерапии' },
  { value: '14', label: 'подходов и методов' },
  { value: '3', label: 'формата работы' },
];
---

<LandingLayout
  title="Духовная психотерапия — Сергей Шанэри"
  description="Индивидуальные терапевтические сессии в духовном подходе. Гештальт-терапия, целительные медитации, работа с подсознанием, регрессии, духовные уроки."
  canonical="therapy/"
>
  <JsonLd data={therapyServiceSchema} slot="head" />

  {/* ─────────────────── HERO ─────────────────── */}
  <section class="hero">
    <div class="hero__aurora" aria-hidden="true"></div>
    <div class="ln-shell ln-shell--narrow hero__inner">
      <div class="hero__meta" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Терапевтические сессии · Сергей Шанэри
        </span>
      </div>

      <h1 class="ln-display hero__title" data-reveal data-reveal-delay="1">
        Духовная<br />
        <em>психотерапия.</em>
      </h1>

      <p class="ln-lead hero__lead" data-reveal data-reveal-delay="2">
        Терапевтические консультации и&nbsp;целительные медитации.
        Помогу понять свои чувства, определить духовный урок
        и&nbsp;жить счастливее.
      </p>

      <div class="hero__actions" data-reveal data-reveal-delay="3">
        <a class="ln-btn ln-btn--primary" href={`${base}contact/`}>
          <span class="ln-btn__shine" aria-hidden="true"></span>
          <span>Записаться</span>
          <span class="ln-btn__icon" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M4 12L12 4M12 4H6M12 4V10" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
        <a class="ln-btn ln-btn--ghost" href="#pricing">
          <span>Что входит</span>
          <span class="ln-btn__icon" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M4 6L8 10L12 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      </div>

      <div class="hero__stats" data-reveal data-reveal-delay="4">
        {stats.map((s) => (
          <div class="hero__stat">
            <span class="hero__stat-value">{s.value}</span>
            <span class="hero__stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-label">Прокрутить</span>
      <span class="hero__scroll-line"></span>
    </div>
  </section>

  {/* ─────────────────── ВВЕДЕНИЕ + ВИДЕО ─────────────────── */}
  <section class="intro ln-section">
    <div class="ln-shell intro__grid">
      <header class="intro__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Зачем нужны сессии
        </span>
        <h2 class="ln-h2 intro__title">
          Разобраться в&nbsp;негативных чувствах<br />
          <em>и&nbsp;выйти на&nbsp;новый уровень счастья.</em>
        </h2>
        <p class="ln-body intro__body">
          Терапевтические сессии нужны, когда возникают негативные эмоции
          и&nbsp;нет понимания, что с&nbsp;ними делать. Когда хочется отпустить
          тяжёлое прошлое и&nbsp;выйти на&nbsp;новый уровень счастья.
        </p>

        <blockquote class="intro__quote">
          <span aria-hidden="true" class="intro__quote-mark">“</span>
          <p>
            Духовный подход помогает увидеть смысл во&nbsp;всём происходящем,
            понять свои духовные уроки, принять свой путь и&nbsp;соединиться
            с&nbsp;силой Духа внутри.
          </p>
        </blockquote>

        <p class="ln-body intro__body">
          Психотерапия помогает разобраться в&nbsp;глубинных причинах чувств,
          освободиться от&nbsp;них и&nbsp;вывести жизнь на&nbsp;новый уровень.
          Духовная психология дополняет это смыслом, мягкостью и&nbsp;целительными
          медитациями.
        </p>
      </header>

      <div class="intro__media" data-reveal data-reveal-delay="2">
        <div class="ln-bezel intro__video-bezel">
          <div class="ln-bezel__inner intro__video-inner">
            <iframe
              src="https://www.youtube-nocookie.com/embed/YKiKsDv29wY"
              title="Зачем нужны терапевтические сессии"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
        <p class="intro__caption">
          <em>Короткое введение: зачем нужны терапевтические сессии и как они работают.</em>
        </p>
      </div>
    </div>
  </section>

  {/* ─────────────────── ЗАПРОСЫ ─────────────────── */}
  <section class="concerns ln-section ln-section--tight">
    <div class="ln-shell">
      <header class="concerns__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          С чем работаю
        </span>
        <h2 class="ln-h2 concerns__title">
          Запросы,<br />
          <em>с&nbsp;которыми прихожу на&nbsp;помощь.</em>
        </h2>
      </header>

      <ul class="chip-grid concerns__grid" data-reveal data-reveal-delay="1">
        {concerns.map((item) => (
          <li class="chip-grid__item">
            <svg class="chip-grid__mark" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
              <circle cx="6" cy="6" r="4.5" opacity="0.35" />
              <circle cx="6" cy="6" r="1.5" fill="currentColor" stroke="none" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ─────────────────── ПОДХОДЫ ─────────────────── */}
  <section class="approaches ln-section ln-section--tight">
    <div class="ln-shell">
      <header class="concerns__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Подходы и методы
        </span>
        <h2 class="ln-h2 concerns__title">
          Инструменты,<br />
          <em>которые применяю в&nbsp;работе.</em>
        </h2>
      </header>

      <ul class="chip-grid chip-grid--approaches" data-reveal data-reveal-delay="1">
        {approaches.map((item) => (
          <li class="chip-grid__item">
            <svg class="chip-grid__mark" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
              <circle cx="6" cy="6" r="4.5" opacity="0.35" />
              <circle cx="6" cy="6" r="1.5" fill="currentColor" stroke="none" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ─────────────────── РЕЗУЛЬТАТ ─────────────────── */}
  <section class="outcomes ln-section">
    <div class="ln-shell outcomes__grid">
      <header class="outcomes__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          К чему приводит
        </span>
        <h2 class="ln-h2 outcomes__title">
          Результат —<br />
          <em>что меняется.</em>
        </h2>
        <p class="ln-body outcomes__body">
          Не&nbsp;обещаю готовых ответов — помогаю их&nbsp;в&nbsp;себе найти. Сессии
          складываются в&nbsp;новое состояние: больше энергии, ясности
          и&nbsp;доверия себе.
        </p>
      </header>

      <ul class="outcomes__list" data-reveal data-reveal-delay="1">
        {outcomes.map((item) => (
          <li class="outcomes__item">
            <svg class="outcomes__check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
              <path d="M3 8.5L6.5 12L13 4.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ─────────────────── ТАРИФЫ ─────────────────── */}
  <section id="pricing" class="pricing ln-section">
    <div class="ln-shell ln-shell--wide">
      <header class="pricing__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Стоимость
        </span>
        <h2 class="ln-h2 pricing__title">
          Три формата —<br />
          <em>от&nbsp;знакомства до&nbsp;длительного ведения.</em>
        </h2>
      </header>

      <div class="pricing__grid">
        {tiers.map((tier, i) => (
          <article
            class:list={['pricing__card ln-bezel', tier.featured && 'pricing__card--featured']}
            data-reveal
            data-reveal-delay={i + 1}
          >
            <div class="ln-bezel__inner pricing__card-inner">
              <header class="pricing__card-head">
                <h3 class="ln-h3 pricing__card-name">{tier.name}</h3>
                <p class="pricing__card-lead">{tier.lead}</p>
              </header>

              <div class="pricing__price">
                <span class="pricing__price-value">{tier.price}</span>
                <span class="pricing__price-note">{tier.priceNote}</span>
              </div>

              <ul class="pricing__features">
                {tier.items.map((item) => (
                  <li>
                    <svg class="pricing__check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
                      <path d="M3 8.5L6.5 12L13 4.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>

              <a
                class:list={['pricing__cta', 'ln-btn', tier.featured ? 'ln-btn--primary' : 'ln-btn--ghost']}

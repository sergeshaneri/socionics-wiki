  }

  .hero__scroll-line {
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(180deg, currentColor, transparent);
  }

  @keyframes hero-fade {
    0%, 100% { opacity: 0.65; transform: translateX(-50%) translateY(0); }
    50% { opacity: 0.25; transform: translateX(-50%) translateY(6px); }
  }

  @media (max-width: 640px) {
    .hero__stats { grid-template-columns: 1fr; gap: 1.75rem; }
    .hero__scroll { display: none; }
  }


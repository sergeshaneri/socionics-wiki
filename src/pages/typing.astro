  /* ═══════════════════════════════════════════════════════════════
     FAQ
     ═══════════════════════════════════════════════════════════════ */
  .faq__grid {
    display: grid;
    grid-template-columns: 0.85fr 1.3fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }

  .faq__head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    position: sticky;
    top: 7rem;
  }

  .faq__body { max-width: 24rem; }

  .faq__inline {
    color: var(--ln-accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    transition: color 300ms;
  }
  .faq__inline:hover { color: #d7c4ff; }

  .faq__list {
    display: flex;
    flex-direction: column;
  }

  .faq__item {
    position: relative;
    border-top: 1px solid var(--ln-line-faint);
    transition: background 500ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .faq__item:last-child { border-bottom: 1px solid var(--ln-line-faint); }

  /* Creeping accent line on the left — appears from top on hover */
  .faq__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg,
      transparent,
      rgba(184, 157, 255, 0.5) 30%,
      rgba(184, 157, 255, 0.5) 70%,
      transparent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 700ms cubic-bezier(0.32, 0.72, 0, 1);
    pointer-events: none;
  }
  .faq__item:hover::before,
  .faq__item[open]::before { transform: scaleY(1); }

  .faq__item[open] {
    background: linear-gradient(180deg, rgba(184, 157, 255, 0.04), transparent 85%);
  }

  .faq__summary {
    display: grid;
    grid-template-columns: 1fr 2.2rem;
    gap: 1.5rem;
    align-items: center;
    padding: 1.5rem 0.25rem 1.5rem 1.25rem;
    cursor: pointer;
    list-style: none;
  }
  .faq__summary::-webkit-details-marker { display: none; }

  .faq__q {
    font-family: var(--ln-font-display);
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    font-weight: 500;
    line-height: 1.35;
    color: var(--ln-ink-body);
    letter-spacing: -0.003em;
    transition: color 400ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .faq__item:hover .faq__q,
  .faq__item[open] .faq__q { color: var(--ln-ink-strong); }

  .faq__icon {
    width: 2.2rem;
    height: 2.2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid var(--ln-line);
    background: transparent;
    color: var(--ln-ink-mute);
    transition:
      border-color 500ms cubic-bezier(0.32, 0.72, 0, 1),
      color 400ms cubic-bezier(0.32, 0.72, 0, 1),
      background 500ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .faq__icon svg { width: 0.85rem; height: 0.85rem; }
  .faq__icon-v {
    transform-origin: center;
    transition: transform 500ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .faq__item:hover .faq__icon {
    border-color: rgba(184, 157, 255, 0.3);
    color: var(--ln-accent);
  }
  .faq__item[open] .faq__icon {
    border-color: rgba(184, 157, 255, 0.4);
    background: rgba(184, 157, 255, 0.06);
    color: var(--ln-accent);
  }
  .faq__item[open] .faq__icon-v {
    transform: scaleY(0);
  }

  .faq__answer {
    padding: 0 3rem 1.75rem 1.25rem;
    animation: faq-in 600ms cubic-bezier(0.19, 1, 0.22, 1);
  }
  .faq__answer p {
    font-family: var(--ln-font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ln-ink-body);
    margin: 0;
    max-width: 38rem;
  }

  @keyframes faq-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .faq__grid { grid-template-columns: 1fr; }
    .faq__head { position: static; }
    .faq__summary { grid-template-columns: 1fr 2rem; gap: 1rem; padding-left: 1rem; }
    .faq__answer { padding: 0 1rem 1.5rem 1rem; }
  }


---
import LandingLayout from '../layouts/LandingLayout.astro';
import ReviewsCarousel from '../components/landing/ReviewsCarousel.astro';
import RelatedServices from '../components/landing/RelatedServices.astro';
import reviews from '../data/reviews-typing.json';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const tiers = [
  {
    num: '01',
    name: 'Проверка ТИМа',
    price: '3 000 ₽',
    priceNote: '30 минут',
    lead: 'Когда ТИМ уже определён — и нужно убедиться.',
    items: [
      'Консультация-знакомство 30 минут онлайн',
      'Базовые вопросы и проверка ключевых признаков',
      'Разбор проявлений интертипных отношений',
      'Ответы на ваши готовые вопросы',
      'Запись встречи',
    ],
    ctaLabel: 'Записаться',
  },
  {
    num: '02',
    name: 'Типирование',
    price: '7 000 ₽',
    priceNote: '1 час',
    lead: 'Полноценное интервью с диагностикой ТИМа и аргументацией.',
    items: [
      'Консультация-интервью 1 час',
      'Вопросы на признаки Рейнина и их зависимости',
      'Вопросы на аспекты и модель А',
      'Уточняющие вопросы при альтернативной версии',
      'Аргументация по всем ответам',
      'Ответы на ваши готовые вопросы',
      'Запись встречи',
    ],
    ctaLabel: 'Записаться',
    featured: true,
  },
  {
    num: '03',
    name: 'Индивидуальное погружение',
    price: '40 000 ₽',
    priceNote: 'месяц',
    lead: 'Авторское обучение и развитие соционической осознанности за месяц.',
    items: [
      'Месяц теории и практики',
      '4 консультации по функциям (1,5 ч) + большая встреча (2 ч)',
      'Материалы, домашние задания и поддержка в обучении',
      'Психологические беседы и индивидуальные рекомендации',
      'Соционическая обратная связь по вашим ситуациям',
      'Запись всех встреч',
    ],
    ctaLabel: 'Записаться',
  },
];

const faqs = [
  {
    q: 'Типирование происходит на основе опросника? Какие используются вопросы?',
    a: 'Да. Я в ходе личной практики и изучения соционики составил собственные вопросы. Сначала я спрашиваю по признакам Рейнина — вопросы устроены так, чтобы признаки перепроверяли друг друга благодаря линейной зависимости. Если ответы не сходятся, я знаю где искать ошибку. После признаков задаю вопросы на информационные аспекты и функции в модели А. Порядок вопросов подстраивается под ответы и то, насколько они сходятся.',
  },
  {
    q: 'Я уже много типировался и получил разные результаты. Что делать, если запутался в противоречивых аргументах?',
    a: 'Вам нужно самостоятельно хорошо разобраться. На индивидуальном погружении в соционику я помогаю прочувствовать и осознать свой ТИМ — где какая функция, где какие аспекты. Помогаю разобраться в семантике ситуаций и «настроить» слух на соционическую семантику.',
  },
  {
    q: 'Узнаю ли я своё предназначение? В чём моя миссия? Какое у меня призвание?',
    a: 'Соционика помогает осознать себя, сонастроиться с собой, соединиться с собой. Всё это — залог ощущения своего предназначения. На самом деле мы всегда его выполняем, задача достаточно сонастроиться с собой, чтобы это ощутить и более искусно пользоваться.',
  },
  {
    q: 'Что я получу в результате типирования?',
    a: 'Информацию о себе, обратную связь. Материал и инструменты для изучения себя и поддержку в этом пути. Для меня важно научить навыку соционической осознанности и соединения со своим ТИМом. Умение понимать, в чём смысл ситуаций, помогает как в саморегуляции, так и в отношениях с людьми. Соционика — это психологическая грамота.',
  },
  {
    q: 'Поможет ли мне соционика обрести вдохновение?',
    a: 'Соционическая осознанность — когда понимаешь своё мышление, его особенности, начинаешь более ловко и от того творчески, вдохновлённо пользоваться собой.',
  },
  {
    q: 'Поможет ли мне типирование нащупать источник счастья?',
    a: 'Счастье — это естественное состояние целостного человека. Так случилось, что сейчас большинство людей травмировано и не может позволить себе быть полноценно счастливыми. Каждый сам ответственен за своё счастье. Психотерапия и духовные практики — отличные подходы для того, чтобы восстановить психологическую целостность и стать счастливым. Соционика может подсветить сферы, в которых работа более актуальна, и в принципе помогает лучше понимать такие абстрактные явления.',
  },
  {
    q: 'Соционика расскажет о моих взаимоотношениях с противоположным полом?',
    a: 'Отношения именно с противоположным полом особенно сильно связаны с семейной историей, и здесь полезнее семейная психология и психотерапия. На погружении в соционику есть большая встреча для ответов на вопросы или терапевтической практики по запросу. Соционика объясняет динамику любых отношений — с роднёй, коллегами любого пола. У каждых отношений есть их главная тема, аттрактор, и если уметь ими пользоваться, то можно проживать их удобно, ловко и эмоционально комфортно. Есть миф, что в партнёры нужно выбирать себе только дуала. Лучше не мешать такими ограничивающими убеждениями своему сердцу. Любые отношения могут быть счастливыми или не очень, слушать и выбирать нужно в согласии с собой.',
  },
  {
    q: 'Я узнаю свои сильные и слабые стороны? В чём моя уникальность?',
    a: 'Соционика помогает увидеть жизнь с разных граней и примерить их все к себе. На погружении в соционику я даю задания и практики на осознание себя с разных сторон. Помогаю осознать, какие из них более уверенные, а какие нет. Важно, что как психолог я подсвечиваю индивидуальное — то, что связано не с соционикой.',
  },
  {
    q: 'Как лучше себя узнать и понять?',
    a: 'Чтобы себя лучше понять, нужно за собой наблюдать и быть честным с собой, доверять себе. Это навыки, которые нужно восстанавливать и поддерживать. Соционическая осознанность, умение наблюдать за разными аспектами себя — отличный инструмент для самопознания.',
  },
  {
    q: 'Соционика поможет мне принять и полюбить себя?',
    a: 'Такими вопросами более специализированно занимается психотерапия. Соционика поможет найти более удобный подход к терапевтическим проработкам.',
  },
  {
    q: 'Используется ли анализ семантики при типировании?',
    a: 'Да, кроме специальной методики вопросов, я, конечно, использую семантический анализ, а также анализ интертипных отношений.',
  },
];

const methodItems = [
  'Признаки Рейнина с перекрёстной проверкой',
  'Информационные аспекты и модель А',
  'Мини-обучение и погружение в соционику',
  'Индивидуальная психологическая оптика',
];

const bioList = [
  'Опыт в соционике — 12 лет',
  'Учился соционике у Семёна Чурюмова',
  'Автор собственной методики типирования',
  'Более 2 000 типирований',
  'Более 20 докладов на соционических конференциях',
  'Опыт в психотерапии — 8 лет',
  'Обучался психологии у Екатерины Самойловой',
];

const stats = [
  { value: '2 000+', label: 'проведённых типирований' },
  { value: '12+', label: 'лет практики в соционике' },
  { value: '20+', label: 'докладов на конференциях' },
];
---

<LandingLayout
  title="Соционическое типирование — Сергей Шанэри"
  description="Уникальная методика типирования с элементами психологии и обучения. Интервью, признаки Рейнина, модель А и соционическая осознанность."
  canonical="typing/"
>
  {/* ─────────────────── HERO ─────────────────── */}
  <section class="hero">
    <div class="hero__aurora" aria-hidden="true"></div>
    <div class="ln-shell ln-shell--narrow hero__inner">
      <div class="hero__meta" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Типирование · Сергей Шанэри
        </span>
      </div>

      <h1 class="ln-display hero__title" data-reveal data-reveal-delay="1">
        Соционическое<br />
        <em>Типирование.</em>
      </h1>

      <p class="ln-lead hero__lead" data-reveal data-reveal-delay="2">
        Научу навыку соционической осознанности и соединения со своим ТИМом —
        не просто определю тип, а помогу его прожить.
      </p>

      <div class="hero__actions" data-reveal data-reveal-delay="3">
        <a class="ln-btn ln-btn--primary" href={`${base}contact/`}>
          <span class="ln-btn__shine" aria-hidden="true"></span>
          <span>Записаться</span>
          <span class="ln-btn__icon" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M4 12L12 4M12 4H6M12 4V10" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
        <a class="ln-btn ln-btn--ghost" href="#pricing">
          <span>Что входит</span>
          <span class="ln-btn__icon" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M4 6L8 10L12 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      </div>

      <div class="hero__stats" data-reveal data-reveal-delay="4">
        {stats.map((s) => (
          <div class="hero__stat">
            <span class="hero__stat-value">{s.value}</span>
            <span class="hero__stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-label">Прокрутить</span>
      <span class="hero__scroll-line"></span>
    </div>
  </section>

  {/* ─────────────────── МЕТОДИКА ─────────────────── */}
  <section class="intro ln-section">
    <div class="ln-shell intro__grid">
      <header class="intro__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Методика
        </span>
        <h2 class="ln-h2 intro__title">
          Психологическое общение<br />
          <em>на тему соционики.</em>
        </h2>
        <p class="ln-body intro__body">
          Типирование — это разговор с целью определить ТИМ (тип информационного
          метаболизма), убедиться в&nbsp;нём и, конечно, понять себя.
        </p>

        <blockquote class="intro__quote">
          <span aria-hidden="true" class="intro__quote-mark">“</span>
          <p>
            Лингвистически выверенные вопросы с&nbsp;опытом психологической практики
            помогают мне отделять ваше индивидуальное от&nbsp;проявлений ТИМа.
          </p>
        </blockquote>

        <a class="ln-underlink" href={`${base}applied/oprosnik-ehkspress-tipirovanie/`}>
          <span>Подробнее о методике — доклад и конспект</span>
          <span aria-hidden="true">→</span>
        </a>
      </header>

      <div class="intro__media" data-reveal data-reveal-delay="2">
        <div class="ln-bezel intro__video-bezel">
          <div class="ln-bezel__inner intro__video-inner">
            <iframe
              src="https://www.youtube-nocookie.com/embed/miyAQBsdlVI"
              title="Соционическое типирование — введение"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
        <p class="intro__caption">
          <em>Если не знаете, что такое типирование — вот введение: что это, как и зачем.</em>
        </p>
      </div>

    </div>

    <div class="ln-shell intro__methods" data-reveal data-reveal-delay="2">
      <ul class="intro__method">
        {methodItems.map((label) => (
          <li class="intro__method-item">
            <svg class="intro__method-mark" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
              <circle cx="6" cy="6" r="4.5" opacity="0.35" />
              <circle cx="6" cy="6" r="1.5" fill="currentColor" stroke="none" />
            </svg>
            <span class="intro__method-label">{label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ─────────────────── ТАРИФЫ ─────────────────── */}
  <section id="pricing" class="pricing ln-section">
    <div class="ln-shell ln-shell--wide">
      <header class="pricing__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Тарифы
        </span>
        <h2 class="ln-h2 pricing__title">
          Три формата —<br />
          <em>подбираем под задачу.</em>
        </h2>
      </header>

      <div class="pricing__grid">
        {tiers.map((tier, i) => (
          <article
            class:list={['pricing__card ln-bezel', tier.featured && 'pricing__card--featured']}
            data-reveal
            data-reveal-delay={i + 1}
          >
            <div class="ln-bezel__inner pricing__card-inner">
              <header class="pricing__card-head">
                <h3 class="ln-h3 pricing__card-name">{tier.name}</h3>
                <p class="pricing__card-lead">{tier.lead}</p>
              </header>

              <div class="pricing__price">
                <span class="pricing__price-value">{tier.price}</span>
                <span class="pricing__price-note">{tier.priceNote}</span>
              </div>

              <ul class="pricing__features">
                {tier.items.map((item) => (
                  <li>
                    <svg class="pricing__check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
                      <path d="M3 8.5L6.5 12L13 4.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>

              <a
                class:list={['pricing__cta', 'ln-btn', tier.featured ? 'ln-btn--primary' : 'ln-btn--ghost']}
                href={`${base}contact/`}
              >
                {tier.featured && <span class="ln-btn__shine" aria-hidden="true"></span>}
                <span>{tier.ctaLabel}</span>
                <span class="ln-btn__icon" aria-hidden="true">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
                    <path d="M4 12L12 4M12 4H6M12 4V10" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </a>

              {tier.featured && <span class="pricing__badge">Основной</span>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ─────────────────── ТЕСТ ─────────────────── */}
  <section class="test ln-section ln-section--tight">
    <div class="ln-shell ln-shell--narrow test__head" data-reveal>
      <span class="ln-eyebrow">
        <span class="ln-eyebrow__dot"></span>
        Прикидка
      </span>
      <h2 class="ln-h2 test__title">
        Короткий тест —<br />
        <em>чтобы нащупать вектор.</em>
      </h2>
      <p class="ln-body test__body">
        Быстрая прикидка — не&nbsp;замена полноценному типированию, но&nbsp;ориентир.
        Результат можно обсудить на&nbsp;консультации.
      </p>
    </div>

    <div class="ln-shell test__frame-wrap" data-reveal data-reveal-delay="1">
      <div class="ln-bezel test__bezel">
        <div class="ln-bezel__inner test__frame">
          <iframe
            src="https://sergeshaneri.github.io/Socionics/"
            title="Соционический тест"
            loading="lazy"
            allow="clipboard-write"
          ></iframe>
        </div>
      </div>
      <a
        class="ln-underlink test__external"
        href="https://sergeshaneri.github.io/Socionics/"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span>Открыть тест в новой вкладке</span>
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </section>

  {/* ─────────────────── ОТЗЫВЫ ─────────────────── */}
  <section class="reviews ln-section">
    <div class="ln-shell">
      <header class="reviews__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Отзывы
        </span>
        <h2 class="ln-h2 reviews__title">
          Что говорят<br />
          <em>те, кто уже прошёл.</em>
        </h2>
        <a
          class="ln-underlink reviews__more"
          href="https://vk.com/topic-113543027_34887526"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>Больше отзывов на VK</span>
          <span aria-hidden="true">↗</span>
        </a>
      </header>

      <div data-reveal data-reveal-delay="1">
        <ReviewsCarousel reviews={reviews} id="typing" />
      </div>
    </div>
  </section>

  {/* ─────────────────── FAQ ─────────────────── */}
  <section class="faq ln-section">
    <div class="ln-shell faq__grid">
      <header class="faq__head" data-reveal>
        <span class="ln-eyebrow">
          <span class="ln-eyebrow__dot"></span>
          Частые вопросы
        </span>
        <h2 class="ln-h2 faq__title">
          Частые<br />
          <em>вопросы.</em>
        </h2>
        <p class="ln-body faq__body">
          Если вашего вопроса нет — задайте его в&nbsp;
          <a href={`${base}contact/`} class="faq__inline">контактах</a>,
          отвечу лично.
        </p>
      </header>

      <div class="faq__list" data-reveal data-reveal-delay="1">
        {faqs.map((item, i) => (
          <details class="faq__item" name="faq">
            <summary class="faq__summary">
              <span class="faq__q">{item.q}</span>
              <span class="faq__icon" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2">
                  <line x1="4" y1="8" x2="12" y2="8" stroke-linecap="round" />
                  <line class="faq__icon-v" x1="8" y1="4" x2="8" y2="12" stroke-linecap="round" />
                </svg>
              </span>
            </summary>
            <div class="faq__answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ─────────────────── FINAL CTA ─────────────────── */}
  <section class="final ln-section">
    <div class="ln-shell ln-shell--narrow">
      <div class="final__card ln-bezel" data-reveal>
        <div class="ln-bezel__inner final__inner">
          <div class="final__glow" aria-hidden="true"></div>
          <span class="ln-eyebrow">
            <span class="ln-eyebrow__dot"></span>
            Следующий шаг
          </span>
          <p class="final__question ln-h2">
            Хочешь разобраться<br />
            <em>и убедиться в своём типе?</em>
          </p>
          <a class="ln-btn ln-btn--primary final__cta" href={`${base}contact/`}>
            <span class="ln-btn__shine" aria-hidden="true"></span>
            <span>Записаться на типирование</span>
            <span class="ln-btn__icon" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
                <path d="M4 12L12 4M12 4H6M12 4V10" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
          <p class="final__sub">
            Онлайн · час внимательного разговора · запись остаётся у&nbsp;вас
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ─────────────────── BIO ─────────────────── */}
  <section class="bio ln-section ln-section--tight">
    <div class="ln-shell bio__grid">
      <div class="bio__photo-wrap" data-reveal>
        <div class="ln-bezel bio__photo-bezel">

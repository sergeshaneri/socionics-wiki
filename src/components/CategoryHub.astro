---
/**
 * Hub-страница категории. Принимает массив папок и собирает все статьи из них
 * через getCollection('docs'), группируя по верхней папке.
 * Сортировка — по заголовку (локаль ru).
 */
import { getCollection } from 'astro:content';

interface Props {
  folders: string[];
  /** Подписи к группам — по ключу-папке */
  labels?: Record<string, string>;
}

const { folders, labels = {} } = Astro.props;

const all = await getCollection('docs');

const groups: Array<{ folder: string; label: string; entries: typeof all }> = [];

for (const folder of folders) {
  const prefix = folder.replace(/\/$/, '') + '/';
  const entries = all
    .filter((e) => e.id.startsWith(prefix) && !e.id.endsWith('/index') && e.id !== prefix.replace(/\/$/, ''))
    .sort((a, b) => (a.data.title || a.id).localeCompare(b.data.title || b.id, 'ru'));
  if (entries.length === 0) continue;
  groups.push({ folder, label: labels[folder] || folder, entries });
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="category-hub">
  {groups.map(({ folder, label, entries }) => (
    <section class="hub-section">
      <h2 class="hub-section__title">{label} <span class="hub-section__count">({entries.length})</span></h2>
      <ul class="hub-list">
        {entries.map((e) => (
          <li>
            <a href={`${base}/${e.id.replace(/\.(md|mdx)$/, '')}/`} class="hub-link">
              <span class="hub-link__title">{e.data.title}</span>
              {e.data.description && e.data.description !== e.data.title && (
                <span class="hub-link__desc">{e.data.description}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</div>

<style>
  .category-hub {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .hub-section__title {
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 1.4vw, 1.3rem);
    font-weight: 500;
    letter-spacing: 0.01em;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 0.5px solid var(--sl-color-hairline, rgba(230, 225, 255, 0.12));
  }

  .hub-section__count {
    color: var(--sl-color-text-weak);
    font-weight: 400;
    font-size: 0.9em;
  }

  .hub-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.6rem 1.5rem;
  }

  .hub-link {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.5rem 0.75rem;
    text-decoration: none;
    border-left: 2px solid transparent;
    border-radius: 4px;
    transition: border-color 160ms ease, background 160ms ease;
  }

  .hub-link:hover,
  .hub-link:focus-visible {
    border-left-color: rgba(199, 160, 255, 0.55);
    background: rgba(199, 160, 255, 0.06);
  }

  .hub-link__title {
    color: var(--sl-color-white);
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.3;
  }

  .hub-link__desc {
    color: var(--sl-color-text-weak);
    font-size: 0.82rem;
    line-height: 1.4;
  }

  :global(:root[data-theme='light']) .hub-link__title {
    color: #1a1627;
  }

  :global(:root[data-theme='light']) .hub-link__desc {
    color: rgba(26, 22, 39, 0.7);
  }

  :global(:root[data-theme='light']) .hub-link:hover,
  :global(:root[data-theme='light']) .hub-link:focus-visible {
    border-left-color: rgba(106, 27, 154, 0.55);
    background: rgba(106, 27, 154, 0.06);
  }
</style>

---
/**
 * Editorial-отзыв: большая italic кавычка Cormorant как декор,
 * текст отзыва, атрибуция small-caps с hairline сверху.
 * Ссылка на источник опциональна.
 */
interface Props {
  author: string;
  text: string;
  source?: string;
  sourceLabel?: string;
}

const { author, text, source, sourceLabel = 'Оригинал' } = Astro.props;
---

<figure class="testimonial">
  <span class="testimonial__mark" aria-hidden="true">«</span>
  <blockquote class="testimonial__text">{text}</blockquote>
  <figcaption class="testimonial__caption">
    <span class="testimonial__author">{author}</span>
    {source && (
      <a class="testimonial__source" href={source} target="_blank" rel="noopener noreferrer">
        {sourceLabel}
        <span aria-hidden="true" class="testimonial__arrow">↗</span>
      </a>
    )}
  </figcaption>
</figure>

<style>
  .testimonial {
    position: relative;
    margin: 0;
    padding: 2.2rem 1.9rem 1.7rem;
    border: 0.5px solid var(--sl-color-hairline);
    border-radius: 22px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.015), rgba(255, 255, 255, 0)),
      rgba(14, 14, 22, 0.5);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    height: 100%;
  }

  .testimonial__mark {
    position: absolute;
    top: 0.2rem;
    left: 1.2rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: 5rem;
    line-height: 1;
    color: var(--sl-color-accent-high, #c7a0ff);
    opacity: 0.18;
    pointer-events: none;
    user-select: none;
  }

  .testimonial__text {
    margin: 0;
    font-family: var(--font-body, inherit);
    font-size: 0.96rem;
    line-height: 1.65;
    color: var(--sl-color-text);
    font-weight: 400;
    white-space: pre-line;
  }

  .testimonial__caption {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding-top: 0.9rem;
    border-top: 0.5px solid var(--sl-color-hairline);
  }

  .testimonial__author {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sl-color-text-strong);
  }

  .testimonial__source {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--sl-color-text-weak);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .testimonial__source:hover {
    color: var(--sl-color-accent-high, #c7a0ff);
  }

  .testimonial__arrow {
    font-size: 0.8em;
    opacity: 0.7;
  }

  /* Светлая тема */
  :global(:root[data-theme='light']) .testimonial {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0.2)),
      rgba(255, 255, 255, 0.4);
  }

  :global(:root[data-theme='light']) .testimonial__mark {
    color: #6a1b9a;
    opacity: 0.22;
  }

  :global(:root[data-theme='light']) .testimonial__text {
    color: rgba(26, 22, 39, 0.88);
  }

  :global(:root[data-theme='light']) .testimonial__author {
    color: #1a1627;
  }

  :global(:root[data-theme='light']) .testimonial__source {
    color: rgba(26, 22, 39, 0.6);
  }

  :global(:root[data-theme='light']) .testimonial__source:hover {
    color: #6a1b9a;
  }
</style>

---
/**
 * Клиентские эффекты Minimal Noir:
 * 1. Scroll-darken — обновляет --scroll-depth при прокрутке.
 * 2. Wiki-hover-preview — показывает карточку с excerpt при hover
 *    над внутренней ссылкой. Fetch + кэш.
 */
---

<script>
  // === 1. Scroll-darken ==================================================
  const MAX_DEPTH_PX = 1800;
  let ticking = false;

  function updateDepth() {
    const depth = Math.min(window.scrollY / MAX_DEPTH_PX, 1);
    document.documentElement.style.setProperty('--scroll-depth', String(depth));
    ticking = false;
  }

  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(updateDepth);
  }

  updateDepth();
  document.addEventListener('scroll', onScroll, { passive: true });
  document.addEventListener('astro:page-load', updateDepth);

  // === 2. Wiki hover-preview =============================================
  type PreviewData = { title: string; excerpt: string };
  const cache = new Map<string, Promise<PreviewData | null>>();

  async function fetchPreview(href: string): Promise<PreviewData | null> {
    if (cache.has(href)) return cache.get(href)!;
    const p = (async () => {
      try {
        const res = await fetch(href, { headers: { Accept: 'text/html' } });
        if (!res.ok) return null;
        const html = await res.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const title = doc.querySelector('#_top')?.textContent?.trim() ?? '';
        const firstPara = doc.querySelector('.sl-markdown-content p');
        let excerpt = firstPara?.textContent?.trim() ?? '';
        if (excerpt.length > 220) excerpt = excerpt.slice(0, 220).trimEnd() + '…';
        if (!title) return null;
        return { title, excerpt };
      } catch {
        return null;
      }
    })();
    cache.set(href, p);
    return p;
  }

  let tooltipEl: HTMLDivElement | null = null;
  let showTimer: number | null = null;
  let currentLink: HTMLAnchorElement | null = null;

  function ensureTooltip() {
    if (tooltipEl) return tooltipEl;
    tooltipEl = document.createElement('div');
    tooltipEl.className = 'wiki-preview';
    tooltipEl.setAttribute('role', 'tooltip');
    tooltipEl.innerHTML = '<h4 class="wiki-preview__title"></h4><p class="wiki-preview__excerpt"></p>';
    document.body.appendChild(tooltipEl);
    return tooltipEl;
  }

  function positionTooltip(evt: MouseEvent, el: HTMLElement) {
    const margin = 14;
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    const elRect = el.getBoundingClientRect();
    let left = evt.clientX + margin;
    let top = evt.clientY + margin;
    if (left + elRect.width + 20 > vw) left = evt.clientX - elRect.width - margin;
    if (top + elRect.height + 20 > vh) top = evt.clientY - elRect.height - margin;
    el.style.left = Math.max(8, left) + 'px';
    el.style.top = Math.max(8, top) + 'px';
  }

  function hide() {
    if (showTimer) { clearTimeout(showTimer); showTimer = null; }
    if (tooltipEl) tooltipEl.classList.remove('is-visible');
    currentLink = null;
  }

  function bindLink(link: HTMLAnchorElement) {
    if (link.dataset.wikiPreviewBound) return;
    link.dataset.wikiPreviewBound = '1';

    link.addEventListener('mouseenter', (evt) => {
      if (link.classList.contains('is-broken')) return;
      const href = link.getAttribute('href');
      if (!href || href.startsWith('#')) return;
      currentLink = link;
      if (showTimer) clearTimeout(showTimer);
      showTimer = window.setTimeout(async () => {
        const data = await fetchPreview(href);
        if (currentLink !== link || !data) return;
        const el = ensureTooltip();
        el.querySelector('.wiki-preview__title')!.textContent = data.title;
        el.querySelector('.wiki-preview__excerpt')!.textContent = data.excerpt || '…';
        positionTooltip(evt as MouseEvent, el);
        el.classList.add('is-visible');
      }, 380);
    });

    link.addEventListener('mousemove', (evt) => {
      if (tooltipEl && tooltipEl.classList.contains('is-visible') && currentLink === link) {
        positionTooltip(evt, tooltipEl);
      }
    });

    link.addEventListener('mouseleave', hide);
    link.addEventListener('blur', hide);
  }

  function bindAll() {
    document.querySelectorAll<HTMLAnchorElement>('a.internal-link').forEach(bindLink);
  }

  bindAll();
  document.addEventListener('astro:page-load', bindAll);
  // На случай динамической подгрузки контента
  const mo = new MutationObserver(bindAll);
  mo.observe(document.body, { childList: true, subtree: true });
</script>

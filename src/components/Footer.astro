---
/**
 * Кастомный Footer — добавляет CTA «Обсудить в соционическом чате»
 * над дефолтным Starlight-футером. Скрывается на splash-страницах
 * (там собственные CTA-секции).
 */
import Default from '@astrojs/starlight/components/Footer.astro';
import Backlinks from './Backlinks.astro';

const { entry } = Astro.locals.starlightRoute;
const isSplash = entry.data.template === 'splash';
const showDiscuss = !isSplash;
const showBacklinks = !isSplash;
const showThanks = !isSplash;

const chatUrl = 'https://t.me/+3PS2UiI8Dec4NWZi';
const thanksUrl = `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}thanks/`;
---

{showBacklinks && <Backlinks entry={entry} />}

{
  showDiscuss && (
    <aside class="discuss-cta not-content" aria-label="Обсудить статью">
      <div class="discuss-cta__inner">
        <div class="discuss-cta__text">
          <span class="discuss-cta__eyebrow">Обсудить</span>
          <p class="discuss-cta__lead">
            Есть вопросы или хочется поделиться мыслями? Присоединяйтесь к соционическому чату.
          </p>
        </div>
        <a
          class="discuss-cta__btn"
          href={chatUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            class="discuss-cta__icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
          <span>Обсудить в чате</span>
          <span class="discuss-cta__shevron" aria-hidden="true">›</span>
        </a>
      </div>
    </aside>
  )
}

{
  showThanks && (
    <p class="thanks-line not-content">
      <span>Если материалы были полезны — </span>
      <a href={thanksUrl}>можно поблагодарить</a>
      <span class="thanks-line__arrow" aria-hidden="true"> ›</span>
    </p>
  )
}

<Default><slot /></Default>

<style>
  .discuss-cta {
    margin: 3rem 0 2rem;
    padding: 1.6rem 1.7rem;
    border: 0.5px solid var(--sl-color-hairline, rgba(230, 225, 255, 0.1));
    border-radius: 18px;
    background:
      linear-gradient(170deg, rgba(28, 22, 46, 0.55), rgba(14, 10, 26, 0.65));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 8px 28px -16px rgba(123, 44, 191, 0.28);
  }

  .discuss-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .discuss-cta__text {
    flex: 1;
    min-width: 16rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .discuss-cta__eyebrow {
    font-family: var(--font-mono, 'Space Mono', monospace);
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--sl-color-text-weak);
    opacity: 0.78;
  }

  .discuss-cta__lead {
    margin: 0;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--sl-color-text);
  }

  .discuss-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    padding: 0.72rem 1.25rem;
    font-family: var(--font-heading);
    font-size: 0.98rem;
    font-weight: 500;
    letter-spacing: 0.015em;
    color: var(--sl-color-white);
    background: rgba(60, 38, 108, 0.55);
    border: 0.5px solid rgba(199, 160, 255, 0.4);
    border-radius: 12px;
    text-decoration: none;
    box-shadow: 0 6px 18px -8px rgba(123, 44, 191, 0.35);
    transition:
      background 220ms ease,
      border-color 220ms ease,
      transform 220ms ease;
    flex-shrink: 0;
  }

  .discuss-cta__btn:hover {
    background: rgba(80, 50, 140, 0.72);
    border-color: rgba(199, 160, 255, 0.65);
    transform: translateY(-1px);
  }

  .discuss-cta__icon {
    width: 1.05rem;
    height: 1.05rem;
    color: rgba(199, 160, 255, 0.95);
    flex-shrink: 0;
  }

  .discuss-cta__shevron {
    font-weight: 300;
    transition: transform 220ms ease;
  }

  .discuss-cta__btn:hover .discuss-cta__shevron {
    transform: translateX(0.2em);
  }

  @media (max-width: 540px) {
    .discuss-cta { padding: 1.4rem 1.3rem; }
    .discuss-cta__btn { width: 100%; justify-content: center; }
  }

  /* Светлая тема */
  :global(:root[data-theme='light']) .discuss-cta {
    background:
      linear-gradient(170deg, rgba(245, 240, 255, 0.85), rgba(235, 228, 255, 0.7));
    border-color: rgba(106, 27, 154, 0.14);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 4px 18px rgba(106, 27, 154, 0.08);
  }

  :global(:root[data-theme='light']) .discuss-cta__lead {
    color: rgba(26, 22, 39, 0.82);
  }

  :global(:root[data-theme='light']) .discuss-cta__eyebrow {
    color: rgba(26, 22, 39, 0.6);
  }

  :global(:root[data-theme='light']) .discuss-cta__btn {
    color: #1a1627;
    background: rgba(235, 225, 255, 0.88);
    border-color: rgba(106, 27, 154, 0.45);
  }

  :global(:root[data-theme='light']) .discuss-cta__btn:hover {
    background: rgba(225, 210, 255, 0.98);
    border-color: rgba(106, 27, 154, 0.7);
  }

  :global(:root[data-theme='light']) .discuss-cta__icon {
    color: #6a1b9a;
  }

  /* Тонкая строка «можно поблагодарить» — без давления */
  .thanks-line {
    margin: 1.5rem 0 2.2rem;
    text-align: center;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--sl-color-text-weak);
    opacity: 0.78;
  }

  .thanks-line a {
    color: var(--sl-color-text);
    text-decoration: none;
    border-bottom: 0.5px solid rgba(199, 160, 255, 0.4);
    padding-bottom: 0.1em;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .thanks-line a:hover,
  .thanks-line a:focus-visible {
    color: var(--sl-color-white);
    border-color: rgba(199, 160, 255, 0.85);
  }

  .thanks-line__arrow {
    color: var(--sl-color-text-weak);
    opacity: 0.55;
  }

  :global(:root[data-theme='light']) .thanks-line {
    color: rgba(26, 22, 39, 0.62);
  }
  :global(:root[data-theme='light']) .thanks-line a {
    color: rgba(26, 22, 39, 0.85);
    border-color: rgba(106, 27, 154, 0.45);
  }
  :global(:root[data-theme='light']) .thanks-line a:hover,
  :global(:root[data-theme='light']) .thanks-line a:focus-visible {
    color: #1a1627;
    border-color: rgba(106, 27, 154, 0.85);
  }
</style>

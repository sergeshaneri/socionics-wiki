---
/**
 * Перелинковка между лендингами «Также интересно».
 * Показывает 3 услуги, отличные от текущей. Префикс base подхватывается.
 */
interface Props {
  current: 'typing' | 'human-design' | 'therapy' | 'teo';
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const services = [
  {
    slug: 'typing',
    title: 'Соционическое типирование',
    tagline: 'Авторская методика — диагностика ТИМа и обучение самонаблюдению',
    price: 'От 3 000 ₽',
  },
  {
    slug: 'human-design',
    title: 'Дизайн Человека',
    tagline: 'Интегральный разбор бодиграфа и Генных Ключей',
    price: 'От 3 000 ₽',
  },
  {
    slug: 'therapy',
    title: 'Духовная психотерапия',
    tagline: 'Индивидуальные сессии и целительные медитации',
    price: 'От 1 000 ₽',
  },
  {
    slug: 'teo',
    title: 'ТЭО — групповая практика',
    tagline: 'Техника Эмоциональной Осознанности в поле группы',
    price: '1 000 ₽ · группа',
  },
];

const others = services.filter((s) => s.slug !== current);
---

<section class="related ln-section ln-section--tight" aria-label="Также интересно">
  <div class="ln-shell">
    <div class="related__head" data-reveal>
      <span class="ln-eyebrow"><span class="ln-eyebrow__dot"></span>Также интересно</span>
      <h2 class="ln-h2 related__title">
        Другие <em>направления.</em>
      </h2>
    </div>

    <div class="related__grid">
      {
        others.map((s, i) => (
          <a
            class="ln-bezel related__card"
            href={`${base}${s.slug}/`}
            data-reveal
            data-reveal-delay={i + 1}
          >
            <div class="ln-bezel__inner related__inner">
              <span class="related__price">{s.price}</span>
              <h3 class="related__name">{s.title}</h3>
              <p class="related__tagline">{s.tagline}</p>
              <span class="related__arrow" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
                  <path d="M4 12L12 4M12 4H6M12 4V10" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .related {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .related__head {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .related__title {
    margin: 0;
  }
  .related__title em {
    font-style: italic;
    color: var(--ln-accent);
  }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .related__grid {
      grid-template-columns: 1fr;
    }
  }

  .related__card {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 500ms var(--ln-ease-silk);
  }
  .related__card:hover {
    transform: translateY(-3px);
  }

  .related__inner {
    position: relative;
    padding: 1.6rem 1.7rem 1.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    height: 100%;
    min-height: 11rem;
  }

  .related__price {
    font-family: var(--ln-font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ln-ink-mute);
  }

  .related__name {
    margin: 0;
    font-family: var(--ln-font-display);
    font-size: clamp(1.15rem, 1.6vw, 1.35rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.005em;
    color: var(--ln-ink-strong);
  }

  .related__tagline {
    margin: 0;
    font-family: var(--ln-font-display);
    font-style: italic;
    font-size: 0.98rem;
    line-height: 1.5;
    color: var(--ln-ink-body);
    flex-grow: 1;
  }

  .related__arrow {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 1.85rem;
    height: 1.85rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(230, 225, 255, 0.04);
    border: 1px solid var(--ln-line);
    color: var(--ln-ink-mute);
    transition:
      transform 500ms var(--ln-ease-silk),
      background 400ms var(--ln-ease-silk),
      border-color 400ms var(--ln-ease-silk),
      color 300ms var(--ln-ease-silk);
  }
  .related__arrow svg {
    width: 0.85rem;
    height: 0.85rem;
  }

  .related__card:hover .related__arrow {
    transform: translate(2px, -2px);
    background: rgba(184, 157, 255, 0.12);
    border-color: rgba(184, 157, 255, 0.35);
    color: var(--ln-accent);
  }
</style>

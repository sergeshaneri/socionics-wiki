        <path fill="#179BD7" d="M115.434 13.075h-3.273c-.281 0-.52.204-.562.481l-.145.916-.23-.332c-.709-1.029-2.289-1.373-3.867-1.373-3.619 0-6.709 2.741-7.311 6.586-.312 1.918.131 3.752 1.219 5.031 1 1.176 2.426 1.666 4.125 1.666 2.916 0 4.533-1.875 4.533-1.875l-.146.91c-.055.348.213.66.564.66h2.949c.467 0 .865-.34.938-.803l1.771-11.209c.057-.348-.211-.658-.565-.658zm-4.565 6.374c-.314 1.871-1.801 3.127-3.695 3.127-.949 0-1.711-.305-2.199-.883-.484-.574-.666-1.391-.514-2.301.297-1.855 1.805-3.152 3.67-3.152.93 0 1.686.309 2.184.892.503.591.701 1.413.554 2.317z"/>
        <path fill="#179BD7" d="M119.295 7.23l-2.807 17.858c-.055.346.213.658.562.658h2.822c.469 0 .867-.34.939-.803l2.768-17.536c.055-.346-.213-.659-.562-.659h-3.16c-.279 0-.519.204-.562.482z"/>
        <path fill="#253B80" d="M7.266 29.154l.523-3.322-1.165-.027H1.061L4.927 1.292C4.939 1.218 4.978 1.149 5.035 1.1c.057-.049.13-.076.206-.076h9.38c3.114 0 5.263.648 6.385 1.927.526.6.861 1.227 1.023 1.917.17.724.173 1.589.007 2.644l-.012.077v.676l.526.298c.443.235.795.504 1.065.812.45.513.741 1.165.864 1.938.127.795.085 1.741-.123 2.812-.24 1.232-.628 2.305-1.152 3.183-.482.809-1.096 1.48-1.825 2-.696.494-1.523.869-2.458 1.109-.906.236-1.939.355-3.072.355h-.73c-.522 0-1.029.188-1.427.525-.399.344-.663.814-.744 1.328l-.055.299-.924 5.855-.042.215c-.011.068-.03.102-.058.125-.025.021-.061.035-.096.035H7.266z"/>
        <path fill="#179BD7" d="M23.048 7.667c-.028.179-.06.362-.096.55-1.237 6.351-5.469 8.545-10.874 8.545H9.326c-.661 0-1.218.48-1.321 1.132l-1.409 8.936-.399 2.533c-.067.428.263.814.695.814h4.881c.578 0 1.069-.42 1.16-.99l.048-.248.919-5.832.059-.32c.09-.572.582-.992 1.16-.992h.73c4.729 0 8.431-1.92 9.513-7.476.452-2.321.218-4.259-.978-5.622-.361-.412-.81-.753-1.335-1.031z"/>
        <path fill="#222D65" d="M21.754 7.151c-.189-.055-.384-.105-.584-.15-.201-.044-.407-.083-.619-.117-.742-.12-1.555-.177-2.426-.177h-7.352c-.181 0-.353.041-.507.115-.339.162-.591.483-.652.876L8.05 17.605l-.045.289c.103-.652.66-1.132 1.321-1.132h2.752c5.405 0 9.637-2.195 10.874-8.545.037-.188.068-.371.096-.55-.313-.166-.652-.308-1.017-.429-.094-.03-.187-.059-.281-.087z"/>
        <path fill="#253B80" d="M9.614 7.699c.061-.393.313-.714.652-.876.155-.074.326-.115.507-.115h7.352c.871 0 1.684.057 2.426.177.212.034.418.073.619.117.2.045.395.095.584.15.094.028.187.057.278.086.365.121.704.264 1.017.429.368-2.347-.003-3.945-1.272-5.392C20.378.682 17.853 0 14.622 0h-9.38c-.66 0-1.223.48-1.325 1.133L.01 25.898c-.077.49.301.932.795.932h5.791l1.454-9.225 1.564-9.906z"/>
      </svg>
    </span>
    <span class="thanks-card__eyebrow">PayPal</span>
    <h2 class="thanks-card__title">paypal.me</h2>
    <a
      class="thanks-card__cta"
      href="https://paypal.me/tatyanayansberg"
      target="_blank"
      rel="noopener noreferrer"
    >
      Перейти к&nbsp;оплате
      <span aria-hidden="true">›</span>
    </a>
    <span class="thanks-card__hint">paypal.me/tatyanayansberg</span>
  </article>
</div>

<p class="thanks-outro">
  Спасибо. Любая поддержка — это сигнал, что время на материалы потрачено не зря.
</p>

<style>
  .thanks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 19rem), 1fr));
    gap: 1.1rem;
    margin: 2.5rem auto 2rem;
    max-width: 64rem;
  }

  .thanks-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.8rem 1.6rem 1.5rem;
    border: 0.5px solid var(--sl-color-hairline, rgba(230, 225, 255, 0.12));
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(20, 16, 32, 0.5), rgba(14, 10, 24, 0.6));
    transition: border-color 240ms ease, transform 240ms ease, box-shadow 240ms ease;
  }

  .thanks-card:hover {
    border-color: rgba(199, 160, 255, 0.32);
    transform: translateY(-2px);
    box-shadow: 0 14px 36px -22px rgba(123, 44, 191, 0.5);
  }

  .thanks-card__icon {
    display: inline-flex;
    align-items: center;
    height: 2.1rem;
    margin-bottom: 0.25rem;
    /* СБП — квадратная, ограничиваем по высоте */
    width: auto;
  }
  .thanks-card__icon svg {
    height: 100%;
    width: auto;
    display: block;
    /* СБП цветной — на тёмной теме чуть приглушаем, чтобы не «кричал»,
       а на hover — возвращаем полную яркость */
    opacity: 0.92;
    transition: opacity 240ms ease, filter 240ms ease;
  }
  /* Wordmark-логотипы (Ozon, PayPal) — длинные, делаем чуть ниже,
     чтобы по «оптической плотности» совпадали с квадратным СБП */
  .thanks-card__icon--wordmark {
    height: 1.45rem;
  }
  .thanks-card:hover .thanks-card__icon svg {
    opacity: 1;
  }

  .thanks-card__eyebrow {
    font-family: var(--font-mono, 'Space Mono', monospace);
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--sl-color-text-weak);
    opacity: 0.86;
  }

  .thanks-card__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 1.7vw, 1.55rem);
    font-weight: 500;
    line-height: 1.15;
    color: var(--sl-color-white);
    letter-spacing: 0.005em;
  }

  .thanks-card__value-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .thanks-card__value {
    font-family: var(--font-mono, 'Space Mono', monospace);
    font-size: 0.98rem;
    letter-spacing: 0.04em;
    color: var(--sl-color-text-strong);
    background: rgba(255, 255, 255, 0.04);
    border: 0.5px solid rgba(230, 225, 255, 0.08);
    padding: 0.45rem 0.7rem;
    border-radius: 6px;
    flex: 1 1 auto;
  }

  .thanks-card__copy {
    flex-shrink: 0;
    font-family: var(--font-mono, 'Space Mono', monospace);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.45rem 0.85rem;
    color: var(--sl-color-text-weak);
    background: transparent;
    border: 0.5px solid rgba(199, 160, 255, 0.25);
    border-radius: 999px;
    cursor: pointer;
    transition: color 200ms ease, border-color 200ms ease, background 200ms ease;
  }
  .thanks-card__copy:hover {
    color: var(--sl-color-white);
    border-color: rgba(199, 160, 255, 0.55);
    background: rgba(199, 160, 255, 0.06);
  }
  .thanks-card__copy.is-copied {
    color: rgba(180, 230, 200, 0.95);
    border-color: rgba(180, 230, 200, 0.5);
    background: rgba(80, 140, 100, 0.08);
  }

  .thanks-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    align-self: flex-start;
    margin-top: 0.2rem;
    padding: 0.6rem 1.05rem;
    font-family: var(--font-heading);
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--sl-color-white);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0)),
      linear-gradient(170deg, rgba(74, 32, 132, 0.7), rgba(48, 16, 96, 0.7));
    border: 0.5px solid rgba(199, 160, 255, 0.32);
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 6px 18px -10px rgba(123, 44, 191, 0.4);
    transition: background 240ms ease, border-color 240ms ease, transform 240ms ease;
  }
  .thanks-card__cta:hover {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0)),
      linear-gradient(170deg, rgba(96, 48, 158, 0.78), rgba(64, 24, 120, 0.78));
    border-color: rgba(199, 160, 255, 0.55);
    transform: translateY(-1px);
  }
  .thanks-card__cta span {
    font-weight: 300;
    transition: transform 220ms ease;
  }
  .thanks-card__cta:hover span {
    transform: translateX(0.2em);
  }

  .thanks-card__hint {
    font-family: var(--font-heading);
    font-style: normal;
    font-size: 0.86rem;
    color: var(--sl-color-text-weak);
    opacity: 0.85;
    margin-top: 0.1rem;
  }

  .thanks-outro {
    max-width: 38rem;
    margin: 2.5rem auto 4rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.6;
    text-align: center;
    color: var(--sl-color-text);
    opacity: 0.9;
  }

  /* Светлая тема */
  :global(:root[data-theme='light']) .thanks-card {
    background: rgba(255, 255, 255, 0.55);
    border-color: rgba(26, 22, 39, 0.14);
  }
  :global(:root[data-theme='light']) .thanks-card:hover {
    border-color: rgba(106, 27, 154, 0.4);
    box-shadow: 0 12px 28px rgba(106, 27, 154, 0.1);
  }
  :global(:root[data-theme='light']) .thanks-card__title {
    color: #1a1627;
  }
  :global(:root[data-theme='light']) .thanks-card__eyebrow {
    color: rgba(26, 22, 39, 0.55);
  }
  :global(:root[data-theme='light']) .thanks-card__value {
    color: #1a1627;
    background: rgba(26, 22, 39, 0.04);
    border-color: rgba(26, 22, 39, 0.1);
  }
  :global(:root[data-theme='light']) .thanks-card__copy {
    color: rgba(26, 22, 39, 0.6);
    border-color: rgba(106, 27, 154, 0.32);
  }
  :global(:root[data-theme='light']) .thanks-card__copy:hover {
    color: #1a1627;
    border-color: rgba(106, 27, 154, 0.55);
    background: rgba(123, 44, 191, 0.06);
  }
  :global(:root[data-theme='light']) .thanks-card__hint {
    color: rgba(26, 22, 39, 0.6);
  }
  :global(:root[data-theme='light']) .thanks-outro {
    color: rgba(26, 22, 39, 0.8);
  }
</style>

<script>
  document.querySelectorAll('.thanks-card__copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand('copy');
        } catch {}
        document.body.removeChild(ta);
      }
      const original = btn.textContent;
      btn.textContent = 'скопировано';
      btn.classList.add('is-copied');
      setTimeout(() => {
        btn.textContent = original;
        btn.classList.remove('is-copied');
      }, 1800);
    });
  });
</script>

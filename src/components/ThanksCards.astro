---
/**
 * Карточки реквизитов для страницы /thanks/.
 * Вынесено в .astro потому что в .mdx нельзя <style>/<script>
 * (MDX парсит { } в CSS как JSX expression).
 */
---

<div class="thanks-grid not-content">
  <article class="thanks-card">
    <span class="thanks-card__icon thanks-card__icon--wordmark" aria-hidden="true">
      {/* Ozon official wordmark (Wikimedia Commons) */}
      <svg viewBox="0 0 485 106" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path fill="#005bff" d="M56.49 80.75c12.54-1.59 22.67-11.72 24.27-24.27a28.2 28.2 0 0 0-31.61-31.61C36.6 26.47 26.47 36.6 24.88 49.14a28.2 28.2 0 0 0 31.61 31.61zM58.2.27a53 53 0 0 1 47.16 47.16c3.31 33.4-24.53 61.24-57.94 57.93A53 53 0 0 1 .27 58.2C-3.04 24.8 24.8-3.04 58.2.27zm75.5 2.09h77.31c2.94 0 4.6 3.36 2.83 5.7l-53.49 70.57h41.91c7.64 0 13.65 6.95 12.07 14.87-1.16 5.81-6.61 9.77-12.53 9.77h-83.96c-2.91 0-4.56-3.33-2.81-5.64L168.56 27h-34.4c-5.92 0-11.37-3.97-12.53-9.77-1.59-7.92 4.43-14.87 12.07-14.87zm335.51.28c7.98-1.68 15 4.36 15 12.04v85.03c0 2.97-3.43 4.62-5.75 2.78l-66.69-52.91v41.39c0 7.68-7.02 13.72-15 12.04-5.72-1.2-9.64-6.53-9.64-12.37V5.91c0-2.97 3.43-4.62 5.75-2.78l66.7 52.91V15.01c0-5.84 3.93-11.16 9.64-12.37zM295.56 0c40.83 0 73.93 23.64 73.93 52.8s-33.1 52.8-73.93 52.8-73.93-23.64-73.93-52.8S254.73 0 295.56 0zm0 24.64c-28.21 0-49.29 14.87-49.29 28.16s21.08 28.16 49.29 28.16 49.29-14.86 49.29-28.16-21.08-28.16-49.29-28.16z"/>
      </svg>
    </span>
    <span class="thanks-card__eyebrow">Карта</span>
    <h2 class="thanks-card__title">Озон&nbsp;Банк</h2>
    <div class="thanks-card__value-row">
      <code class="thanks-card__value">2204 3210 0164 0333</code>
      <button
        type="button"
        class="thanks-card__copy"
        data-copy="2204321001640333"
        aria-label="Скопировать номер карты"
      >
        копировать
      </button>
    </div>
  </article>

  <article class="thanks-card">
    <span class="thanks-card__icon" aria-hidden="true">
      {/* СБП: официальный логотип НСПК (8 цветных треугольников = символ объединения банков) */}
      <svg viewBox="0 0 97 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 26.12l14.532 25.975v15.844L.017 93.863 0 26.12z" fill="#5B57A2"/>
        <path d="M55.797 42.643l13.617-8.346 27.868-.026-41.485 25.414V42.643z" fill="#D90751"/>
        <path d="M55.72 25.967l.077 34.39-14.566-8.95V0l14.49 25.967z" fill="#FAB718"/>
        <path d="M97.282 34.271l-27.869.026-13.693-8.33L41.231 0l56.05 34.271z" fill="#ED6F26"/>
        <path d="M55.797 94.007V77.322l-14.566-8.78.008 51.458 14.558-25.993z" fill="#63B22F"/>
        <path d="M69.38 85.737L14.531 52.095 0 26.12l97.223 59.583-27.844.034z" fill="#1487C9"/>
        <path d="M41.24 120l14.556-25.993 13.583-8.27 27.843-.034L41.24 120z" fill="#017F36"/>
        <path d="M.017 93.863l41.333-25.32-13.896-8.526-12.922 7.922L.017 93.863z" fill="#984995"/>
      </svg>
    </span>
    <span class="thanks-card__eyebrow">СБП</span>
    <h2 class="thanks-card__title">По номеру телефона</h2>
    <div class="thanks-card__value-row">
      <code class="thanks-card__value">+7&nbsp;952&nbsp;511-59-37</code>
      <button
        type="button"
        class="thanks-card__copy"
        data-copy="+79525115937"
        aria-label="Скопировать номер телефона"
      >
        копировать
      </button>
    </div>
    <span class="thanks-card__hint">Выбрать Озон Банк</span>
  </article>

  <article class="thanks-card">
    <span class="thanks-card__icon thanks-card__icon--wordmark" aria-hidden="true">
      {/* PayPal official wordmark (Wikimedia Commons) */}
      <svg viewBox="0 0 124 33" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path fill="#253B80" d="M46.211 6.749h-6.839c-.468 0-.866.34-.939.802l-2.766 17.537c-.055.346.213.658.564.658h3.265c.468 0 .866-.34.939-.803l.746-4.73c.072-.463.471-.803.938-.803h2.165c4.505 0 7.105-2.18 7.784-6.5.306-1.89.013-3.375-.872-4.415-.972-1.142-2.696-1.746-4.985-1.746zM47 13.154c-.374 2.454-2.249 2.454-4.062 2.454h-1.032l.724-4.583c.043-.277.283-.481.563-.481h.473c1.235 0 2.4 0 3.002.704.359.42.469 1.044.332 1.906z"/>

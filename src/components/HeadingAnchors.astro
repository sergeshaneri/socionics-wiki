---
/**
 * Прогрессивное улучшение: для каждого заголовка с id в .sl-markdown-content
 * добавляет кнопку-ссылку, копирующую прямой URL в буфер.
 */
---

<script>
  const SELECTOR = '.sl-markdown-content :is(h2, h3, h4)[id]';

  function setup() {
    const headings = document.querySelectorAll<HTMLElement>(SELECTOR);
    headings.forEach((h) => {
      if (h.querySelector('.heading-anchor')) return;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'heading-anchor';
      btn.setAttribute('aria-label', `Скопировать ссылку на «${h.textContent?.trim() ?? ''}»`);
      btn.textContent = '#';
      btn.addEventListener('click', async (ev) => {
        ev.preventDefault();
        const url = `${window.location.origin}${window.location.pathname}#${h.id}`;
        try {
          await navigator.clipboard.writeText(url);
          btn.classList.add('copied');
          btn.textContent = '✓';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.textContent = '#';
          }, 1200);
        } catch {
          /* clipboard denied — тихо игнорируем */
        }
      });
      h.appendChild(btn);
    });
  }

  setup();
  // На случай клиентской навигации Starlight
  document.addEventListener('astro:page-load', setup);
</script>

---
/**
 * Фоновый узор — seamless domain-warped noise (Iñigo Quilez style).
 * Собран из суммы синусоид с целыми частотами → периодичность по
 * размеру тайла, двойной warp создаёт плетёные турбулентные потоки.
 * Результат рендерится один раз в canvas, превращается в Blob URL
 * и накладывается на `body::after` с `background-repeat: repeat`,
 * чтобы прокручиваться вместе с контентом.
 */
---

<style is:global>
  /* Изолируем body, чтобы негативный z-index у ::after остался под
     контентом, но над body-градиентом. */
  body {
    isolation: isolate;
    position: relative;
  }

  body::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    min-height: 100vh;
    pointer-events: none;
    z-index: -1;
    background-image: var(--fractal-bg-url, none);
    background-repeat: repeat;
    background-position: 0 0;
    background-size: 800px 800px;
    opacity: var(--fractal-bg-opacity, 0);
    mix-blend-mode: screen;
    transition: opacity 1000ms ease-out;
  }

  :root[data-theme='light'] body::after {
    mix-blend-mode: multiply;
  }

  @media (prefers-reduced-motion: reduce) {
    body::after { transition: none; }
  }
</style>

<script>
  (function () {
    if (window.innerWidth < 700) return;
    const conn = (navigator as any).connection;
    if (conn?.saveData) return;

    if (document.documentElement.dataset.fractalRendered) return;
    document.documentElement.dataset.fractalRendered = '1';

    const schedule = (window as any).requestIdleCallback ?? ((cb: () => void) => setTimeout(cb, 300));
    schedule(() => render());

    function render() {
      const SIZE = 800; // размер seamless-тайла
      const canvas = document.createElement('canvas');
      canvas.width = SIZE;
      canvas.height = SIZE;
      const ctx = canvas.getContext('2d', { willReadFrequently: false });
      if (!ctx) return;

      const PI2 = Math.PI * 2;

      // Seamless noise: сумма синусоид с ЦЕЛЫМИ частотами. Только низкие
      // октавы — для крупных плавных потоков без мелкой детализации.
      const OCTAVES: Array<[number, number, number, number]> = [
        // [fx, fy, amplitude, phase]
        [1, 1, 1.0, 0.7],
        [2, 1, 0.55, 1.3],
        [1, 2, 0.5, 2.1],
        [2, 2, 0.35, 0.4],
        [3, 2, 0.22, 1.8],
      ];

      function noise(x: number, y: number, seed: number): number {
        let v = 0;
        for (let i = 0; i < OCTAVES.length; i++) {
          const [fx, fy, amp, phase] = OCTAVES[i];
          v += Math.sin(PI2 * fx * x + phase + seed)
            * Math.cos(PI2 * fy * y + phase * 1.37 + seed * 0.73)
            * amp;
        }
        return v;
      }

      // Warp обратно в [0,1), сохраняя seamless-периодичность
      function wrap(v: number): number {
        return ((v % 1) + 1) % 1;
      }

      const img = ctx.createImageData(SIZE, SIZE);
      const data = img.data;

      const WARP1 = 0.28;
      const WARP2 = 0.15;
      const STRIPE_FREQ = 0.6; // плотность полос — в 4× реже прежнего
      const STRIPE_POWER = 14; // резче → тоньше линии

      for (let py = 0; py < SIZE; py++) {
        const y = py / SIZE;
        for (let px = 0; px < SIZE; px++) {
          const x = px / SIZE;

          // Первый warp
          const wx1 = wrap(x + noise(x, y, 0.0) * WARP1);
          const wy1 = wrap(y + noise(x, y, 3.14) * WARP1);

          // Второй warp (двойной warp создаёт турбулентность)
          const wx2 = wrap(wx1 + noise(wx1, wy1, 1.71) * WARP2);
          const wy2 = wrap(wy1 + noise(wx1, wy1, 4.23) * WARP2);

          // Финальный семпл
          const v = noise(wx2, wy2, 6.28);

          // Изолинии: тонкие контуры через sin-stripes
          const stripe = Math.abs(Math.sin(v * Math.PI * STRIPE_FREQ));
          const contour = Math.pow(stripe, STRIPE_POWER);
          const alpha = Math.min(255, contour * 255);

          const i = (py * SIZE + px) * 4;
          data[i] = 230;
          data[i + 1] = 225;
          data[i + 2] = 255;
          data[i + 3] = alpha;
        }
      }
      ctx.putImageData(img, 0, 0);

      canvas.toBlob((blob) => {
        if (!blob) return;
        const url = URL.createObjectURL(blob);
        const root = document.documentElement;
        root.style.setProperty('--fractal-bg-url', `url("${url}")`);
        const isLight = root.dataset.theme === 'light';
        requestAnimationFrame(() => {
          // Линии стали тонкими и редкими — чуть поднимаем непрозрачность,
          // чтобы штрих всё же читался на фоне.
          root.style.setProperty('--fractal-bg-opacity', isLight ? '0.1' : '0.085');
        });
      }, 'image/png');
    }
  })();
</script>

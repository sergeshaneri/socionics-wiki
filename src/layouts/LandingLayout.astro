---
import '../styles/landing.css';
import LandingNav from '../components/landing/LandingNav.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';
import JsonLd from '../components/JsonLd.astro';
import { personSchema } from '../lib/structured-data';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const site = Astro.site ? Astro.site.toString().replace(/\/?$/, '/') : null;
const ogImageUrl = site
  ? new URL(ogImage ?? 'shaneri.jpg', site).toString()
  : `${base}${ogImage ?? 'shaneri.jpg'}`;
const canonicalUrl = canonical
  ? (site ? new URL(canonical, site).toString() : `${base}${canonical.replace(/^\//, '')}`)
  : (site ? new URL(Astro.url.pathname.replace(/^\//, ''), site).toString() : Astro.url.pathname);
---

<!doctype html>
<html lang="ru" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <meta name="theme-color" content="#050509" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#050509" media="(prefers-color-scheme: light)" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <JsonLd data={personSchema} />
    <slot name="head" />
  </head>
  <body class="landing-body">
    <a class="ln-skip" href="#main">К основному содержанию</a>

    <LandingNav />

    <main id="main">
      <slot />
    </main>

    <LandingFooter />

    <style>
      .ln-skip {
        position: absolute;
        top: -100vh;
        left: 1rem;
        z-index: 100;
        padding: 0.6rem 1rem;
        border-radius: 999px;
        background: var(--ln-ink);
        color: var(--ln-bg);
        font-family: var(--ln-font-body);
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        transition: top 300ms cubic-bezier(0.32, 0.72, 0, 1);
      }
      .ln-skip:focus-visible {
        top: 1rem;
      }
    </style>

    <script>
      // Universal scroll-reveal via IntersectionObserver (GPU-safe: transform + opacity + filter only)
      const reveals = document.querySelectorAll<HTMLElement>('[data-reveal]');
      if (reveals.length > 0) {
        const io = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
        reveals.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
